# AWS (Vault service)
AWS_REGION="us-east-1"
# Prefer instance/task roles or workload identity. Do not put real long-lived AWS keys in tracked env files.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
