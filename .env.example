# Shared rate limiting
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Trusted proxy IPs (comma-separated) - used for IP rate limiting.
# Forwarded IP headers are ignored unless this is configured. Set TRUST_CF_CONNECTING_IP=true
# only when the origin is reachable exclusively through Cloudflare.
TRUSTED_PROXY_IPS=""
TRUST_CF_CONNECTING_IP="false"

# Session Configuration
SESSION_IDLE_TIMEOUT_MINUTES="30"
ALLOWED_ORIGINS="http://localhost:3000,https://hips.org"

# Admin
ADMIN_DASHBOARD_URL=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# CDK Deployment
IMAGE_TAG="latest"
DOMAIN="hips.internal"
