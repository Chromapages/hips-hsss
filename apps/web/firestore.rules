rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is an admin
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'ADMIN';
    }

    // Helper function to check if user is a facilitator
    function isFacilitator() {
      return request.auth != null && request.auth.token.role == 'FACILITATOR';
    }

    // Users collection: users can read their own document; admins can read all
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Sessions collection: participants can read their own sessions
    match /sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Safety alerts: admin only
    match /safetyAlerts/{alertId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // Session flags: anonymous write allowed, read for facilitators/admins
    match /sessionFlags/{flagId} {
      allow read: if isAuthenticated() && (isFacilitator() || isAdmin());
      allow create: if isAuthenticated(); // Allow authenticated users to create flags
    }

    // Packages: users can read their own
    match /packages/{packageId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Scholarships: users can read their own
    match /scholarships/{scholarshipId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false; // Write only via backend
    }

    // Inquiries: public create, admin read
    match /inquiries/{inquiryId} {
      allow create: if true; // Public submission
      allow read: if isAdmin();
    }
  }
}