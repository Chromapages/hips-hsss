{
  "name": "@hips/safety",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate --schema=prisma/safety.prisma"
  },
  "dependencies": {
    "@hips/copy-policy": "workspace:*",
    "@hips/types": "workspace:*",
    "@nestjs/axios": "4.0.1",
    "@nestjs/common": "10.4.22",
    "@nestjs/core": "10.4.22",
    "@nestjs/platform-express": "10.4.22",
    "@prisma/client": "5.22.0",
    "axios": "1.15.2",
    "firebase-admin": "12.7.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/testing": "10.4.22",
    "@types/node": "20.19.39",
    "@vitest/coverage-v8": "1.6.1",
    "eslint": "8.57.1",
    "prettier": "3.8.3",
    "prisma": "5.22.0",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  },
  "prisma": {
    "schema": "prisma/safety.prisma"
  }
