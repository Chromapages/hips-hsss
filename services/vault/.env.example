# Vault Service Environment Variables
# Copy this file to .env and fill in the values

# Database
DATABASE_URL="postgresql://vault_db_user:your-strong-password@localhost:5432/hips_vault"

# AWS KMS Configuration
AWS_REGION="us-east-1"
VAULT_KMS_KEY_ID="arn:aws:kms:us-east-1:123456789012:key/your-key-id"

# Vault API Secret (used for x-vault-secret header auth)
VAULT_API_SECRET="your-vault-api-secret-here"

# Node environment
NODE_ENV="development"
