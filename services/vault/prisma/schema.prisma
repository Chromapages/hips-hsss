// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model IdentityRecord {
  id                            String    @id @default(cuid())
  subjectRef                    String    @unique
  encryptedRealName             Bytes
  encryptedEmergencyContact    Bytes
  encryptedRegion              Bytes
  encryptedDisclosure          Bytes?
  encryptedIpAddress           Bytes?
  ipExpiresAt                  DateTime?
  encryptedDeviceFingerprint  Bytes?
  deviceFingerprintExpiresAt   DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@map("identity_record")
}

model VaultAccessLog {
  id          String   @id @default(cuid())
  subjectRef  String
  actorRef    String
  purpose     String
  action      String?
  metadata    Json     @default("{}")
  timestamp   DateTime @default(now())

  @@index([subjectRef])
  @@index([actorRef])
  @@index([timestamp])
  @@map("vault_access_log")
}
