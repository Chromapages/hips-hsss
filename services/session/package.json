{
  "name": "@hips/session",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate --schema=./prisma/session.prisma",
    "migrate:session": "prisma migrate dev --schema=./prisma/session.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/session.prisma",
    "studio": "prisma studio --schema=./prisma/session.prisma"
  },
  "dependencies": {
    "@hips/types": "workspace:*",
    "@nestjs/axios": "4.0.1",
    "@nestjs/common": "10.4.22",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "10.4.22",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/platform-express": "10.4.22",
    "@nestjs/platform-socket.io": "10.4.22",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/websockets": "10.4.22",
    "@prisma/client": "5.22.0",
    "@types/express": "5.0.6",
    "axios": "1.16.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "@google-cloud/firestore": "7.11.6",
    "firebase-admin": "12.7.0",
    "ioredis": "5.10.1",
    "livekit-server-sdk": "1.2.7",
    "prisma": "5.22.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.3",
    "uuid": "9.0.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.9",
    "@nestjs/testing": "10.4.22",
    "@types/node": "20.19.39",
    "@types/uuid": "9.0.8",
    "@vitest/coverage-v8": "1.6.1",
    "eslint": "8.57.1",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  }
}
