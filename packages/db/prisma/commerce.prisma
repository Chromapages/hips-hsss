generator client {
  provider = "prisma-client-js"
  output   = "../generated/commerce"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  PARTICIPANT
  LEADER
  ORGBUYER
  FACILITATOR
  ADMIN
}

enum ServiceCategory {
  INDIVIDUAL_SUPPORT
  GROUP_SUPPORT
  SUPPORT_NAVIGATION
  CRISIS_PLANNING
  FAMILY_SUPPORT
  ORGANIZATION_TRAINING
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ScholarshipStatus {
  PENDING
  APPROVED
  DENIED
}

enum DonationTier {
  SUPPORTER
  BUILDER
  SUSTAINER
  CATALYST
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
}

model User {
  id          String        @id @default(uuid()) @db.Uuid
  firebaseUid String       @unique
  email       String       @unique
  role        UserRole     @default(PARTICIPANT)
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  sessions    Session[]
  packages    Package[]
  scholarships Scholarship[]
  donations   Donation[]

  @@index([role])
  @@index([deletedAt])
}

model Service {
  id                     String          @id @default(uuid()) @db.Uuid
  slug                   String          @unique
  name                   String
  category               ServiceCategory
  priceCents             Int
  scholarshipMinCents    Int
  scholarshipMaxCents    Int
  active                 Boolean         @default(true)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  sessions               Session[]
  packages               Package[]

  @@index([category])
  @@index([active])
}

model Session {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @db.Uuid
  serviceId       String        @db.Uuid
  packageId       String?       @db.Uuid
  status          SessionStatus @default(SCHEDULED)
  startsAt        DateTime
  endsAt          DateTime
  sessionTokenRef String?       @unique
  stripePaymentId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  service         Service       @relation(fields: [serviceId], references: [id])
  package         Package?      @relation(fields: [packageId], references: [id])

  @@index([userId])
  @@index([serviceId])
  @@index([packageId])
  @@index([status])
  @@index([startsAt])
}

model Package {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  serviceId     String    @db.Uuid
  totalSessions Int
  usedSessions  Int       @default(0)
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id])
  service       Service   @relation(fields: [serviceId], references: [id])
  sessions      Session[]

  @@index([userId])
  @@index([serviceId])
  @@index([expiresAt])
}

model Scholarship {
  id             String            @id @default(uuid()) @db.Uuid
  userId         String            @db.Uuid
  status         ScholarshipStatus @default(PENDING)
  requestedCents Int
  approvedCents  Int?
  note           String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  user           User              @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model Donation {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String?      @db.Uuid
  tier            DonationTier
  amountCents     Int
  stripePaymentId String       @unique
  createdAt       DateTime     @default(now())
  user            User?        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tier])
  @@index([createdAt])
}

model OrgInquiry {
  id          String        @id @default(uuid()) @db.Uuid
  orgName     String
  contactName String
  email       String
  status      InquiryStatus @default(NEW)
  message     String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}
