generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client/safety"
}

datasource db {
  provider = "postgresql"
  url      = env("SAFETY_DATABASE_URL")
}

model SafetyAlert {
  id               String   @id @default(uuid()) @db.Uuid
  sessionId        String
  severity         String   // LOW, MEDIUM, HIGH, CRITICAL
  category         String   // HARM, SELF_HARM, HARASSMENT, DISCLOSURE
  anonymizedReason String
  transcriptChunk  String?  @db.Text
  isResolved       Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model SafetyAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String
  actor     String
  metadata  Json
  createdAt DateTime @default(now())
}
