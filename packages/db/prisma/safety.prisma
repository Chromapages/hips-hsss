generator client {
  provider = "prisma-client-js"
  output   = "../generated/safety"
}

datasource db {
  provider = "postgresql"
  url      = env("SAFETY_DATABASE_URL")
}

model SafetyAlert {
  id               String   @id @default(uuid()) @db.Uuid
  sessionId        String
  severity         String   // LOW, MEDIUM, HIGH, CRITICAL
  category         String   // HARM, SELF_HARM, HARASSMENT, DISCLOSURE
  anonymizedReason String
  transcriptChunk  String?  @db.Text
  isResolved       Boolean  @default(false)
  createdAt        DateTime @default(now())

  mitigations      SafetyMitigation[]
  escalations      EscalationQueue[]
}

model SafetyMitigation {
  id        String   @id @default(uuid()) @db.Uuid
  alertId   String   @db.Uuid
  action    String   // WARNING, MUTE, KICK, ESCALATE
  success   Boolean
  metadata  Json?
  createdAt DateTime @default(now())

  alert     SafetyAlert @relation(fields: [alertId], references: [id])
}

model SafetyStrike {
  id            String   @id @default(uuid()) @db.Uuid
  sessionId     String
  participantId String
  count         Int      @default(1)
  lastStrikeAt  DateTime @default(now())
  createdAt     DateTime @default(now())

  @@unique([sessionId, participantId])
}

model SafetyAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String
  actor     String
  metadata  Json
  createdAt DateTime @default(now())
}

// Persisted escalation queue - replaces in-memory queue
model EscalationQueue {
  id            String       @id @default(uuid()) @db.Uuid
  sessionRef    String
  level         String       // watch, urgent, crisis
  source        String       // keyword, manual
  summary       String
  status        String       @default("open") // open, reviewing, resolved
  reviewerHandle String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  alertId       String?      @db.Uuid
  alert         SafetyAlert? @relation(fields: [alertId], references: [id])

  @@index([status])
  @@index([sessionRef])
}