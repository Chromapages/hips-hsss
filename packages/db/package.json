{
  "name": "@hips/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./generated/commerce": {
      "types": "./generated/commerce/index.d.ts",
      "default": "./generated/commerce/index.js"
    }
  },
  "scripts": {
    "dev": "prisma studio --schema=./prisma/commerce.prisma",
    "generate": "prisma generate --schema=./prisma/commerce.prisma",
    "generate:commerce": "prisma generate --schema=./prisma/commerce.prisma",
    "migrate:commerce": "prisma migrate dev --schema=./prisma/commerce.prisma",
    "migrate:deploy": "prisma migrate deploy --schema=./prisma/commerce.prisma",
    "exec": "ts-node"
  },
  "dependencies": {
    "@prisma/client": "^5.16.0"
  },
  "devDependencies": {
    "prisma": "^5.16.0",
    "typescript": "^5.4.0",
    "dotenv": "^16.4.0",
    "ts-node": "^10.9.0"
  }
}
