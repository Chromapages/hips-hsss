{
  "name": "hips-platform",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "pnpm --filter @hips/web test:e2e",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml}\"",
    "audit": "pnpm audit --audit-level=high",
    "db:migrate:commerce": "pnpm --filter @hips/db exec prisma migrate dev --schema=./prisma/commerce.prisma",
    "db:migrate:session": "pnpm --filter @hips/db exec prisma migrate dev --schema=./prisma/session.prisma",
    "db:studio:commerce": "pnpm --filter @hips/db exec prisma studio --schema=./prisma/commerce.prisma",
    "db:studio:session": "pnpm --filter @hips/db exec prisma studio --schema=./prisma/session.prisma",
    "db:seed": "pnpm --filter @hips/db exec ts-node prisma/seed.ts",
    "copycheck": "node scripts/copycheck.js"
  },
  "pnpm": {
    "overrides": {
      "axios": "1.15.2",
      "glob": "10.5.0",
      "multer": "2.1.1",
      "picomatch": "4.0.4",
      "undici": "6.24.0"
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
